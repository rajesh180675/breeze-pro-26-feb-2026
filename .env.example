# Breeze PRO runtime profile
APP_ENV=production
LOG_LEVEL=INFO

# Breeze Connect credentials
BREEZE_CLIENT_ID=your_breeze_client_id
BREEZE_CLIENT_SECRET=your_breeze_client_secret
BREEZE_SESSION_TOKEN=your_daily_session_token

# Optional metadata exposed by /version
APP_VERSION=11.0.0
APP_BUILD=local
APP_COMMIT=dev

# Storage
SQLITE_DB_PATH=data/breeze_trader.db

# Alerts (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_TO=
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_SECRET=
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=
